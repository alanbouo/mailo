# Email Archiver Configuration
# Copy this file to .env and fill in your actual credentials

# =============================================================================
# EMAIL CONFIGURATION (Required)
# =============================================================================

# Your email address
EMAIL_ADDRESS=your_email@example.com

# Your email password
# For Gmail with 2FA enabled, use an App Password: https://myaccount.google.com/apppasswords
# For Outlook/365 with MFA, use an App Password: https://account.live.com/proofs/AppPassword
EMAIL_PASSWORD=your_password_here

# =============================================================================
# IMAP SERVER CONFIGURATION (Required)
# =============================================================================

# Common IMAP server settings:
# Gmail:           imap.gmail.com        (Port: 993, SSL: true)
# Outlook/365:     outlook.office365.com (Port: 993, SSL: true)
# Yahoo Mail:      imap.mail.yahoo.com   (Port: 993, SSL: true)
# iCloud:          imap.mail.me.com      (Port: 993, SSL: true)
# Custom server:   mail.yourdomain.com   (Port: 993, SSL: true)

IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
USE_SSL=true

# =============================================================================
# ARCHIVING OPTIONS (Optional)
# =============================================================================

# Number of days old emails to archive (default: 365)
DAYS_OLD=365

# Archive directory path (default: ./EmailArchive)
ARCHIVE_DIR=./EmailArchive

# Default folder to archive (leave empty to archive all folders)
# FOLDER=INBOX

# Set to true to delete emails from server after archiving (DANGEROUS!)
# DELETE_AFTER_ARCHIVE=false
